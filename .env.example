SHIELD_API_KEY=
SHIELD_ENCRYPTION_SHARE=
SHIELD_SECRET_KEY=

# Passkey relying party (used by app.config.js → OpenfortProvider walletConfig).
# Must match the RP ID in Openfort/Shield dashboard and the domain that serves assetlinks.json.
# Android: do NOT use localhost – use a real hostname (e.g. ngrok: PASSKEY_RP_ID=abc123.ngrok-free.app).
# Required to test passkey wallet recovery on Android; see README and docs/ANDROID_PASSKEYS_SETUP.md.
# See docs/ANDROID_PASSKEYS_SETUP.md for assetlinks.json and hosting.
PASSKEY_RP_ID=
PASSKEY_RP_NAME=